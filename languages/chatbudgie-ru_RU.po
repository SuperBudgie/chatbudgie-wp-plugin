msgid "Manage your chatbot settings and account."
msgstr "Управляйте настройками и аккаунтом вашего чат-бота."

msgid "knowledge Base Indexing Status"
msgstr "Статус индексации базы знаний"

msgid "Rebuild Index"
msgstr "Перестроить индекс"

