msgstr "Название приложения"

msgid "Site"
msgstr "Сайт"

msgid "Request Type"
msgstr "Тип запроса"

msgid "Token Cost"
msgstr "Стоимость в токенах"

msgid "Time Cost"
msgstr "Затраченное время"

msgid "No request logs found."
msgstr "Журналы запросов не найдены."

msgid "ChatBudgie chat window"
msgstr "Окно чата ChatBudgie"

msgid "ChatBudgie avatar"
msgstr "Аватар ChatBudgie"

msgid "Close chat"
msgstr "Закрыть чат"

msgid "What services do you offer?"
msgstr "Какие услуги вы предлагаете?"

msgid "We offer AI chatbot solutions that help you automate support and engage your visitors."
msgstr "Мы предлагаем решения AI-чатботов, которые помогают автоматизировать поддержку и вовлекать посетителей."

msgid "Is my data safe?"
msgstr "Безопасны ли мои данные?"

msgid "Oops! Something went wrong."
msgstr "Упс! Что-то пошло не так."

msgid "I'm having a little trouble thinking right now. Please try again in a moment."
msgstr "Сейчас мне немного трудно ответить. Повторите попытку через минуту."

msgid "Try Again"
msgstr "Попробовать снова"

msgid "Ask anything..."
msgstr "Спросите что угодно..."

