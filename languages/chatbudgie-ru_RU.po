msgstr "Статус недоступен"

msgid "Check logs"
msgstr "Проверить журналы"

msgid "Ready now"
msgstr "Готово"

msgid "%1$dm %2$02ds"
msgstr "%1$d мин %2$02$d сек"

msgid "%1$ds"
msgstr "%1$d сек"

