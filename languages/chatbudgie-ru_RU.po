msgstr "Закрыть"

msgid "Payment Success!"
msgstr "Платеж успешен!"

msgid "Your transaction has been successfully completed. The tokens will be recharged to your account shortly."
msgstr "Ваша транзакция успешно завершена. Токены скоро будут зачислены на ваш аккаунт."

msgid "Continue"
msgstr "Продолжить"

msgid "I'm ChatBudgie, your AI assistant. How can I help you today?"
msgstr "Я ChatBudgie, ваш AI-помощник. Чем могу помочь сегодня?"

msgid "Preparing index"
msgstr "Подготовка индекса"

msgid "Indexing content"
msgstr "Индексация содержимого"

msgid "Index is ready"
msgstr "Индекс готов"

msgid "Index needs attention"
msgstr "Индекс требует внимания"

