#. Plugin Name of the plugin
#: chatbudgie.php class-chatbudgie.php:1784 class-chatbudgie.php:1785
msgid "ChatBudgie"
msgstr "ChatBudgie"

#. Plugin URI of the plugin
#: chatbudgie.php
msgid "https://github.com/SuperBudgie/chatbudgie-wp-plugin"
msgstr "https://github.com/SuperBudgie/chatbudgie-wp-plugin"

#. Description of the plugin
#: chatbudgie.php
msgid ""
"Display a chat dialog on WordPress pages, allowing users to talk with a RAG-"
"based Agent to get website-related answers"
msgstr ""
"Muestra un cuadro de chat en las páginas de WordPress para que los usuarios "
"hablen con un agente basado en RAG y obtengan respuestas relacionadas con el "
"sitio web"

#. Author of the plugin
#: chatbudgie.php
msgid "SuperBudgie Team"
msgstr "SuperBudgie Team"

#. Author URI of the plugin
