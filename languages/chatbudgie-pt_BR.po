msgid "ChatBudgie"
msgstr "ChatBudgie"

#. Plugin URI of the plugin
#: chatbudgie.php
msgid "https://github.com/SuperBudgie/chatbudgie-wp-plugin"
msgstr "https://github.com/SuperBudgie/chatbudgie-wp-plugin"

#. Description of the plugin
#: chatbudgie.php
msgid ""
"Display a chat dialog on WordPress pages, allowing users to talk with a RAG-"
"based Agent to get website-related answers"
msgstr ""
"Exibe uma janela de chat nas páginas do WordPress, permitindo que os "
"usuários conversem com um agente baseado em RAG para obter respostas "
"relacionadas ao site"

#. Author of the plugin
#: chatbudgie.php
msgid "SuperBudgie Team"
msgstr "SuperBudgie Team"

#. Author URI of the plugin
#: chatbudgie.php
msgid "https://chat.superbudgie.com"
msgstr "https://chat.superbudgie.com"

