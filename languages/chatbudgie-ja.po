#. Description of the plugin
#: chatbudgie.php
msgid ""
"Display a chat dialog on WordPress pages, allowing users to talk with a RAG-"
"based Agent to get website-related answers"
msgstr ""
"WordPress ページにチャットダイアログを表示し、ユーザーが RAG ベースのエージェ"
"ントと会話してサイトに関する回答を得られるようにします"

#. Author of the plugin
#: chatbudgie.php
msgid "SuperBudgie Team"
msgstr "SuperBudgie Team"

#. Author URI of the plugin
#: chatbudgie.php
msgid "https://chat.superbudgie.com"
msgstr "https://chat.superbudgie.com"

