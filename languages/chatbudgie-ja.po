msgstr "取引は正常に完了しました。トークンはまもなくアカウントにチャージされます。"

msgid "Continue"
msgstr "続行"

msgid "I'm ChatBudgie, your AI assistant. How can I help you today?"
msgstr "私はあなたの AI アシスタント ChatBudgie です。本日はどのようにお手伝いできますか？"

msgid "Preparing index"
msgstr "インデックスを準備中"

msgid "Indexing content"
msgstr "コンテンツをインデックス中"

msgid "Index is ready"
msgstr "インデックスは準備完了です"

