msgstr "도움이 필요하거나 질문이 있으신가요?"

msgid "SuperBudgie team is here to assist you."
msgstr "SuperBudgie 팀이 도와드리겠습니다."

msgid "Token Usage"
msgstr "토큰 사용량"

msgid "Monitor your token consumption and request activity."
msgstr "토큰 소비와 요청 활동을 모니터링하세요."

msgid "Request Logs"
msgstr "요청 로그"

msgid "View a detailed history of your chatbot requests and token usage."
msgstr "챗봇 요청과 토큰 사용량의 자세한 기록을 확인하세요."

