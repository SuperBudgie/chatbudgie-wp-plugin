msgstr "이 페이지에 접근할 권한이 없습니다."

msgid "Unauthorized"
msgstr "권한 없음"

msgid "Failed to fetch usage info. Please try again later."
msgstr "사용량 정보를 가져오지 못했습니다. 나중에 다시 시도하세요."

msgid "Failed to fetch user info. Please try again later."
msgstr "사용자 정보를 가져오지 못했습니다. 나중에 다시 시도하세요."

msgid "You do not have permission to complete this action."
msgstr "이 작업을 완료할 권한이 없습니다."

msgid "Invalid login callback request."
msgstr "잘못된 로그인 콜백 요청입니다."

msgid "Login Error"
msgstr "로그인 오류"

msgid "Authorization code is missing"
msgstr "인증 코드가 없습니다"

msgid "API Error"
msgstr "API 오류"

msgid "Failed to retrieve appKey from login server"
msgstr "로그인 서버에서 appKey를 가져오지 못했습니다"

msgid "Failed to fetch account info. Please try again later."
msgstr "계정 정보를 가져오지 못했습니다. 나중에 다시 시도하세요."

msgid "ChatBudgie Workspace"
msgstr "ChatBudgie 워크스페이스"

