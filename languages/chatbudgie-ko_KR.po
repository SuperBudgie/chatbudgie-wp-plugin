msgid "ChatBudgie"
msgstr "ChatBudgie"

msgid "https://github.com/SuperBudgie/chatbudgie-wp-plugin"
msgstr "https://github.com/SuperBudgie/chatbudgie-wp-plugin"

msgid "Display a chat dialog on WordPress pages, allowing users to talk with a RAG-based Agent to get website-related answers"
msgstr "WordPress 페이지에 채팅 대화상자를 표시하여 사용자가 RAG 기반 에이전트와 대화하고 웹사이트 관련 답변을 얻을 수 있게 합니다"

msgid "SuperBudgie Team"
msgstr "SuperBudgie Team"

msgid "https://chat.superbudgie.com"
msgstr "https://chat.superbudgie.com"

msgid "Action Scheduler is unavailable. Please make sure no other plugin is loading an incompatible copy."
msgstr "Action Scheduler를 사용할 수 없습니다. 다른 플러그인이 호환되지 않는 사본을 로드하고 있지 않은지 확인하세요."

msgid "Hi, I'm ChatBudgie, assistant of the website. To use the chat feature, please go to the plugin settings page to connect your ChatBudgie account."
msgstr "안녕하세요, 저는 웹사이트 도우미 ChatBudgie입니다. 채팅 기능을 사용하려면 플러그인 설정 페이지에서 ChatBudgie 계정을 연결하세요."

msgid "Hi, I'm ChatBudgie, assistant of the website. How can I help you today?"
msgstr "안녕하세요, 저는 웹사이트 도우미 ChatBudgie입니다. 오늘 무엇을 도와드릴까요?"

msgid "Please enter your question..."
msgstr "질문을 입력하세요..."

msgid "Failed to send, please try again"
msgstr "전송에 실패했습니다. 다시 시도하세요"

msgid "Are you sure you want to rebuild the index? This action will delete the existing index and rebuild it, it may take some time and consume your tokens."
msgstr "인덱스를 다시 빌드하시겠습니까? 이 작업은 기존 인덱스를 삭제하고 다시 빌드하며, 시간이 걸리고 토큰을 소비할 수 있습니다."

msgid "Choose Icon"
msgstr "아이콘 선택"

msgid "Select Icon"
msgstr "아이콘 선택"

msgid "Failed to create order"
msgstr "주문을 생성하지 못했습니다"

msgid "Failed to capture payment"
msgstr "결제를 캡처하지 못했습니다"

msgid "An error occurred during the transaction:"
msgstr "거래 중 오류가 발생했습니다:"

msgid "Your session has expired. Please refresh the page and try again."
msgstr "세션이 만료되었습니다. 페이지를 새로고침한 후 다시 시도하세요."

msgid "ChatBudgie:"
msgstr "ChatBudgie:"

msgid "Index build is scheduled and will start shortly."
msgstr "인덱스 빌드가 예약되었으며 곧 시작됩니다."

msgid "Indexing progress: %1$d of %2$d posts completed (%3$d%%)"
msgstr "인덱싱 진행률: 게시물 %2$d개 중 %1$d개 완료(%3$d%%)"

msgid "Index build completed successfully."
msgstr "인덱스 빌드가 성공적으로 완료되었습니다."

msgid "Index build failed:"
msgstr "인덱스 빌드 실패:"

